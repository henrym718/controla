# ---- Supabase (local: estos valores salen al correr `supabase start`) ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# secreto para firmar nuestros JWT propios (PIN). En local lo da `supabase start`.
SUPABASE_JWT_SECRET=

# ---- IA / voz ----
GEMINI_API_KEY=
WHISPER_API_KEY=

# ---- Panel de plataforma (super-admin) ----
# El PIN del panel (/panel) se guarda HASHEADO en la base (lo registra el pipeline
# en producción con el secreto de GitHub). Esta variable es solo un FALLBACK para
# desarrollo local, cuando aún no has corrido set_super_pin en tu base local.
SUPER_ADMIN_PIN=123456
